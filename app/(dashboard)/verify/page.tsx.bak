"use client";

import { useState } from "react";
import { motion, AnimatePresence } from "framer-motion";
import { ThumbsUp, ThumbsDown, ShieldAlert, MapPin, CheckCircle } from "lucide-react";

export default function VerifyCommunityPage() {
  const [currentIndex, setCurrentIndex] = useState(0);

  const reportsToVerify = [
    { id: 1, title: "Fallen Tree on Road", location: "Golden Gate Park", time: "10 mins ago", img: "https://images.unsplash.com/photo-1541888087588-66236b281b64?auto=format&fit=crop&q=80&w=600" },
    { id: 2, title: "Flooded Intersection", location: "Downtown", time: "1 hour ago", img: "https://images.unsplash.com/photo-1515694346937-94d85e41e6f0?auto=format&fit=crop&q=80&w=600" },
  ];

  const handleVote = (direction: 'up' | 'down') => {
    setCurrentIndex((prev) => prev + 1);
  };

  return (
    <div className="max-w-xl mx-auto">
      <div className="text-center mb-8">
        <h1 className="text-3xl font-bold text-white mb-2">Community Verification</h1>
        <p className="text-neutral-400">Help verify local reports to earn Hero Points and train our AI models.</p>
      </div>

      <div className="relative h-[600px] w-full">
        <AnimatePresence>
          {currentIndex < reportsToVerify.length ? (
            <motion.div
              key={currentIndex}
              initial={{ opacity: 0, scale: 0.95, y: 20 }}
              animate={{ opacity: 1, scale: 1, y: 0 }}
              exit={{ opacity: 0, scale: 0.95, y: -20, transition: { duration: 0.2 } }}
              className="absolute inset-0 bg-neutral-900 border border-white/10 rounded-3xl overflow-hidden shadow-2xl flex flex-col"
            >
              {/* Image */}
              <div 
                className="h-2/3 w-full bg-cover bg-center"
                style={{ backgroundImage: `url(${reportsToVerify[currentIndex].img})` }}
              >
                <div className="w-full h-full bg-gradient-to-t from-neutral-900 to-transparent flex items-end p-6">
                  <div>
                    <span className="px-3 py-1 bg-red-500/20 text-red-400 text-xs font-bold rounded-full border border-red-500/20 mb-3 inline-block backdrop-blur-md">
                      Requires Verification
                    </span>
                    <h2 className="text-2xl font-bold text-white mb-1">{reportsToVerify[currentIndex].title}</h2>
                    <div className="flex items-center gap-4 text-sm text-neutral-300">
                      <span className="flex items-center gap-1"><MapPin className="w-4 h-4" /> {reportsToVerify[currentIndex].location}</span>
                      <span>{reportsToVerify[currentIndex].time}</span>
                    </div>
                  </div>
                </div>
              </div>

              {/* Actions */}
              <div className="flex-1 flex items-center justify-center gap-8 p-6 bg-neutral-900">
                <button 
                  onClick={() => handleVote('down')}
                  className="w-16 h-16 rounded-full bg-white/5 hover:bg-red-500/10 border border-white/10 hover:border-red-500/30 flex items-center justify-center text-neutral-400 hover:text-red-500 transition-all shadow-lg hover:scale-105 active:scale-95"
                >
                  <ThumbsDown className="w-8 h-8" />
                </button>
                <button 
                  className="w-12 h-12 rounded-full bg-white/5 hover:bg-amber-500/10 border border-white/10 hover:border-amber-500/30 flex items-center justify-center text-neutral-400 hover:text-amber-500 transition-all shadow-lg"
                >
                  <ShieldAlert className="w-5 h-5" />
                </button>
                <button 
                  onClick={() => handleVote('up')}
                  className="w-16 h-16 rounded-full bg-white/5 hover:bg-emerald-500/10 border border-white/10 hover:border-emerald-500/30 flex items-center justify-center text-neutral-400 hover:text-emerald-500 transition-all shadow-lg hover:scale-105 active:scale-95"
                >
                  <ThumbsUp className="w-8 h-8" />
                </button>
              </div>
            </motion.div>
          ) : (
            <motion.div
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              className="absolute inset-0 flex flex-col items-center justify-center text-center p-8 border border-white/5 rounded-3xl bg-white/[0.02]"
            >
              <div className="w-20 h-20 bg-emerald-500/10 rounded-full flex items-center justify-center mb-6">
                <CheckCircle className="w-10 h-10 text-emerald-500" />
              </div>
              <h2 className="text-2xl font-bold text-white mb-2">You're all caught up!</h2>
              <p className="text-neutral-400">You've reviewed all pending reports in your area. You earned 20 Hero Points!</p>
            </motion.div>
          )}
        </AnimatePresence>
      </div>
    </div>
  );
}
